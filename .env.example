# =============================================================================
# 插件开关 (Plugin Feature Flags)
# =============================================================================

# 静默监控插件 - 启用后自动监控文件变化但不输出日志
# 类型: boolean (true/false)
SILENT_WATCH_ENABLED=false

# 认知治理插件 - 启用后对AI输出进行质量评估和调控
# 类型: boolean (true/false)
COGNITIVE_GOVERNOR_ENABLED=false

# 权限哨兵插件 - 启用后对敏感操作进行权限校验
# 类型: boolean (true/false)
PERMISSION_SENTINEL_ENABLED=false

# 输出验证器插件 - 启用后验证AI输出的安全性和格式
# 类型: boolean (true/false)
OUTPUT_VERIFIER_ENABLED=false

# 压力测试插件 - 启用后对Agent进行压力测试
# 类型: boolean (true/false)
STRESS_TESTER_ENABLED=false

# =============================================================================
# 通知渠道配置 (Notification Channel Configuration)
# =============================================================================

# 企业微信/Server酱 WebHook 地址
# 格式: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=***  或  SCTxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SERVER_CHAN_KEY=

# Telegram Bot Token (向 @BotFather 申请)
# 格式: 123456789:ABCdefGHIjklMNOpqrsTUVwxyzYZ
TELEGRAM_BOT_TOKEN=
# Telegram 聊天 ID (使用 @userinfobot 获取)
# 格式: 123456789 (纯数字)
TELEGRAM_CHAT_ID=

# Slack Incoming WebHook URL
# 格式: https://hooks.slack.com/services/XXX/YYY/ZZZ
SLACK_WEBHOOK=

# 飞书机器人 WebHook 地址
# 格式: https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxx
FEISHU_WEBHOOK=

# =============================================================================
# AI/视觉 API 配置 (AI & Vision API Configuration)
# =============================================================================

# 视觉/AI API 密钥 (用于图像识别、内容审核等)
# 格式: sk-xxx...xxxx
VISION_API_KEY=

# =============================================================================
# 邮件配置 (Email/SMTP Configuration)
# =============================================================================

# SMTP 服务器地址
# 格式: smtp.example.com
SMTP_HOST=smtp.gmail.com

# SMTP 端口号
# 格式: 587 (TLS) 或 465 (SSL) 或 25 (无加密)
SMTP_PORT=587

# SMTP 用户名/邮箱
# 格式: your.email@gmail.com
SMTP_USER=

# SMTP 密码/授权码
# 格式: 十六位授权码 (非登录密码)
SMTP_PASS=

# 邮件发件人地址 (留空则使用 SMTP_USER)
FROM_EMAIL=

# 邮件收件人地址
TO_EMAIL=

# =============================================================================
# Server酱配置 (ServerChan Push Configuration) — 已废弃，请使用 SERVER_CHAN_KEY
# =============================================================================

# Server酱 SendKey (从 https://sct.ftqq.com/ 获取)
# 格式: SCTxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 注意: 请优先使用上方的 SERVER_CHAN_KEY
SERVERCHAN_KEY=

# =============================================================================
# 运行时环境 (Runtime Environment)
# =============================================================================

# Node.js 运行环境
# 类型: development / production / test
NODE_ENV=development

# =============================================================================
# 静默监控插件详细配置 (SilentWatch Detailed Configuration)
# =============================================================================

# 最大连续调用同一工具次数（触发告警阈值）
SILENT_WATCH_MAX_CONSECUTIVE_CALLS=10

# 最大连续空响应次数（触发告警阈值）
SILENT_WATCH_MAX_CONSECUTIVE_EMPTY=3

# 单步超时时间（毫秒）
SILENT_WATCH_STEP_TIMEOUT_MS=60000

# 告警上下文中包含的最近事件数量
SILENT_WATCH_CONTEXT_SIZE=10

# HTTP API 认证密钥（可选，用于安全保护）
SILENT_WATCH_API_KEY=

# 是否要求 API 认证
# 类型: true / false
SILENT_WATCH_REQUIRE_AUTH=false

# =============================================================================
# 认知治理插件详细配置 (CognitiveGovernor Detailed Configuration)
# =============================================================================

# Token 上限
COGNITIVE_GOVERNOR_TOKEN_LIMIT=8000

# 压缩阈值 (0.0 - 1.0)
COGNITIVE_GOVERNOR_THRESHOLD=0.7

# 压缩策略
# 类型: smart / aggressive / conservative
COGNITIVE_GOVERNOR_STRATEGY=smart

# =============================================================================
# 压力测试插件详细配置 (Agent Stress Tester Detailed Configuration)
# =============================================================================

# 目标 Agent 名称
TARGET_AGENT=opencli

# 测试超时时间（毫秒）
TEST_TIMEOUT=30000

# 最大并发数
MAX_CONCURRENT=5

# 测试套件列表（逗号分隔）
# 可选值: adversarial, drift, load, normal
TEST_SUITES=adversarial,drift,load,normal

# 漂移阈值 (0.0 - 1.0)
DRIFT_THRESHOLD=0.85

# 负载配置 (JSON 数组格式)
# 示例: [{"name":"spike","type":"spike","duration":60000,"qps":10,"burst":50}]
LOAD_PROFILES=

# =============================================================================
# 输出验证器详细配置 (Output Verifier Detailed Configuration)
# =============================================================================

# 严格程度
# 类型: relaxed / standard / strict
OUTPUT_VERIFIER_STRICTNESS=standard

# 验证报告输出路径
OUTPUT_VERIFIER_REPORT_PATH=./verification-reports.json

# API 验证器 URL
OUTPUT_VERIFIER_API_URL=

# API 验证器密钥
OUTPUT_VERIFIER_API_KEY=

# 视觉 API 密钥（用于截图验证）
OUTPUT_VERIFIER_VISION_API_KEY=
