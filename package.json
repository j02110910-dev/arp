{
  "name": "arp",
  "version": "0.1.0",
  "description": "Agent Reliability Platform - One package for monitoring, verification, memory, and security of AI agents. npm install arp",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:all": "npm run test:silent-watch && npm run test:output-verifier && npm run test:cognitive-governor && npm run test:permission-sentinel && npm run test:agent-stress-tester && npm test",
    "test:silent-watch": "cd plugins/silent-watch && npm test",
    "test:output-verifier": "cd plugins/output-verifier && npm test",
    "test:cognitive-governor": "cd plugins/cognitive-governor && npm test",
    "test:permission-sentinel": "cd plugins/permission-sentinel && npm test",
    "test:agent-stress-tester": "cd plugins/agent-stress-tester && npm test",
    "prepare": "npm run build"
  },
  "keywords": [
    "ai-agent",
    "monitoring",
    "verification",
    "memory",
    "security",
    "agent-reliability",
    "mcp",
    "openclaw",
    "claude-code"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "pino": "^9.14.0",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
